# PMO Equipment Booking & Monitoring System
# Father Saturnino Urios University (FSUU)
# =============================================
# Copy this file to .env.local and fill in values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="PMO Equipment Booking & Monitoring System"

# Email Configuration (Resend)
RESEND_API_KEY=re_your-resend-api-key-here
EMAIL_FROM="PMO FSUU <pmo@fsuu.edu.ph>"

# FSUU Domain Validation
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=fsuu.edu.ph
