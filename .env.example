# Copy this file to .env.local and fill in values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="PMO Equipment Booking & Monitoring System"

# EmailJS Configuration
EMAILJS_SERVICE_ID=service_p7curqr
EMAILJS_TEMPLATE_ID=template_yjvgecf
EMAILJS_API_KEY=your-public-api-key-here
EMAILJS_USER_ID=your-user-id-here
EMAIL_FROM="PMO FSUU <pmo@fsuu.edu.ph>"

# FSUU Domain Validation
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=fsuu.edu.ph
